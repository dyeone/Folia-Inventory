# Supabase — copy this file to .env.local and fill in your values.
# Find these in: Supabase Dashboard → Project Settings → API
#
# SERVICE ROLE KEY IS SECRET. It's only used by server-side API routes
# (files under /api) and is never exposed to the browser.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here
